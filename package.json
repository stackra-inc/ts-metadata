{
  "name": "@stackra/ts-metadata",
  "version": "1.1.0",
  "description": "Typed metadata utilities for TypeScript decorators — define, get, merge, extend, and introspect reflect-metadata with a clean API",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/ts-metadata.git"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/ts-metadata/issues"
  },
  "homepage": "https://github.com/stackra-inc/ts-metadata#readme",
  "keywords": [
    "typescript",
    "metadata",
    "reflect-metadata",
    "decorators",
    "reflection",
    "utilities",
    "nestjs",
    "dependency-injection",
    "di"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "reflect-metadata": {
      "optional": false
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@stackra/eslint-config": "^1.0.0",
    "@stackra/prettier-config": "^1.0.0",
    "@stackra/standardize": "^1.0.2",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@stackra/tsup-config": "^1.0.0",
    "@stackra/typescript-config": "^1.0.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "eslint": "^9.28.0",
      "@eslint/js": "^9.28.0"
    }
  },
  "stackra": {
    "publish": {
      "steering": {
        "source": ".kiro/steering/",
        "destination": ".kiro/steering/{module}/",
        "description": "Kiro AI steering files for metadata"
      },
      "hooks": {
        "source": ".kiro/hooks/",
        "destination": ".kiro/hooks/",
        "description": "Kiro hooks"
      }
    }
  }
}
